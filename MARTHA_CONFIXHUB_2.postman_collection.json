              "    pm.expect(pm.response.code).to.be.oneOf([200,201]);",
              "});",
              "",
              "pm.test(\"Response contains ID\", function () {",
              "    pm.expect(response).to.have.property(\"id\");",
              "});",
              "",
              "pm.collectionVariables.set(\"object_id\", response.id);",
